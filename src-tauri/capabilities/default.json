{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "shell:default",
    "dialog:default",
    {
      "identifier": "core:default",
      "allow": [{ "path": "$HOME/**" }]
    }
  ]
}
