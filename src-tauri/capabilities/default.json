{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "shell:default",
    {
      "identifier": "core:default",
      "allow": [{ "path": "$HOME/**" }]
    },
    {
      "identifier": "core:asset:default",
      "allow": [
        { "path": "$HOME/.imagen-heap/**" },
        { "path": "$HOME/.cache/huggingface/**" }
      ]
    }
  ]
}
